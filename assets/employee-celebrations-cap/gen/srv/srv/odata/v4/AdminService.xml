        <Property Name="department" Type="Edm.String" MaxLength="100"/>
        <Property Name="birthday" Type="Edm.Date"/>
        <Property Name="hireDate" Type="Edm.Date"/>
        <Property Name="photoUrl" Type="Edm.String" MaxLength="500"/>
        <NavigationProperty Name="wishes" Type="Collection(AdminService.Wishes)" Partner="employee">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
      </EntityType>
      <EntityType Name="Wishes">
        <Key>
          <PropertyRef Name="ID"/>
        </Key>
        <Property Name="ID" Type="Edm.Guid" Nullable="false"/>
        <Property Name="createdAt" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="createdBy" Type="Edm.String" MaxLength="255"/>
        <Property Name="modifiedAt" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="modifiedBy" Type="Edm.String" MaxLength="255"/>
        <NavigationProperty Name="employee" Type="AdminService.Employees" Nullable="false" Partner="wishes">
          <ReferentialConstraint Property="employee_ID" ReferencedProperty="ID"/>
        </NavigationProperty>
        <Property Name="employee_ID" Type="Edm.Guid" Nullable="false"/>
        <Property Name="senderName" Type="Edm.String" MaxLength="100"/>
        <Property Name="message" Type="Edm.String" MaxLength="500"/>
        <Property Name="celebrationType" Type="Edm.String" MaxLength="20"/>
      </EntityType>
      <Annotations Target="AdminService.Employees/ID">
        <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
      </Annotations>
      <Annotations Target="AdminService.Employees/createdAt">
        <Annotation Term="UI.HiddenFilter" Bool="true"/>
